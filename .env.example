# Sanity project configuration
# Find these in your Sanity project settings: https://www.sanity.io/manage
# (or run `npx sanity init` / `npx sanity projects list`)
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"

# Sanity API version (date). Leave as-is unless you need a newer API.
NEXT_PUBLIC_SANITY_API_VERSION="2025-03-01"

# Optional: read token for previewing drafts / private datasets.
# Create at https://www.sanity.io/manage -> API -> Tokens (Viewer role is enough).
# SANITY_API_READ_TOKEN=""
